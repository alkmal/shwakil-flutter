{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend PHP Local Debug",
      "type": "shell",
      "command": "php -S 127.0.0.1:8080",
      "options": {
        "cwd": "${workspaceFolder}/backend/php"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Development Server \\(http://127.0.0.1:8080\\) started"
          }
        }
      ]
    }
  ]
}
